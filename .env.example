# Local template defaults. Never commit real credentials.
# The dev script pins port 3000; PORT is also useful for production runtimes.
PORT=3000
DATABASE_URL=postgresql://openfront:openfront@localhost:54321/openfront
SESSION_SECRET=replace-this-with-a-random-secret-of-at-least-32-characters

# Public application URLs
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_REGION=us
PUBLIC_SIGNUPS_ALLOWED=true
HIDE_OPENFRONT_BRANDING=false

# Optional AI assistant
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4.1-mini
# OPENROUTER_MAX_TOKENS=4096

# Optional payments
# NEXT_PUBLIC_STRIPE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=
# NEXT_PUBLIC_PAYPAL_SANDBOX=true
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=
# PAYPAL_API_URL=https://api-m.sandbox.paypal.com

# Optional email
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=no-reply@example.com
# SMTP_STORE_LINK=http://localhost:3000

# Optional Cloudinary storage
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_KEY=
# CLOUDINARY_SECRET=

# Optional S3-compatible images (also allow the host in next.config.ts)
# S3_ENDPOINT=

# Optional storefront settings
# NEXT_PUBLIC_PAYPAL_SANDBOX=true
# NEXT_PUBLIC_VIEW_ORDER=
